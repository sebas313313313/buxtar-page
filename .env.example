# ===========================================
# Buxtar Portfolio - Environment Variables
# ===========================================
# Copy this file as .env and fill in the values
# IMPORTANT: Never commit .env to version control

# API Configuration (for future use)
# All VITE_ prefixed vars are exposed to the client
VITE_API_BASE_URL=https://api.example.com
VITE_CONTACT_FORM_ENDPOINT=https://api.example.com/contact

# Rate Limiting
VITE_RATE_LIMIT_MAX_REQUESTS=3
VITE_RATE_LIMIT_WINDOW_MS=60000

# Google Maps (if needed)
# VITE_GOOGLE_MAPS_API_KEY=your_key_here

# Analytics (if needed)
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX
